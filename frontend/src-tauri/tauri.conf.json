{
  "$schema": "https://raw.githubusercontent.com/nicosanchez/tauri/dev/tooling/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "productName": "AI Market Analyst",
  "version": "1.1.0",
  "identifier": "com.stockanalyzer.market-analyst",
  "app": {
    "windows": [
      {
        "title": "AI Market Analyst",
        "url": "about:blank",
        "width": 1320,
        "height": 880,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:* ws://localhost:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* ws://localhost:* https://*.yahoo.com https://*.finance.yahoo.com; img-src 'self' https: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/sidecar/**"
    ]
  }
}
